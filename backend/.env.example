# ── Server ────────────────────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/fleet_ops_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h

# ── Seed (test credentials only — do not use in production) ───────────────
TEST_MANAGER_EMAIL=manager@fleetops.dev
TEST_MANAGER_PASSWORD=FleetOps2026!

# ── SMTP (Email Delivery) ──────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASS=replace_with_real_password
MAIL_FROM="Fleet Ops <noreply@example.com>"

# ── Web Push (VAPID) ───────────────────────────────────────────────────────────
# Generate keys once: node -e "import('web-push').then(m => console.log(m.default.generateVAPIDKeys()))"
# Store the output here. Never commit real keys to the repository.
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_MAILTO=mailto:admin@fleetops.dev
